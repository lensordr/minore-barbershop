# Database
DATABASE_URL=postgresql://user:password@host/dbname

# Brevo SMTP (email)
BREVO_SMTP_USER=your-brevo-login@email.com
BREVO_SMTP_PASSWORD=your-brevo-smtp-key
EMAIL_FROM=noreply@yourdomain.com

# App
BASE_URL=https://your-app.onrender.com
DEFAULT_LOCATION=1

# Admin credentials (override defaults in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production
REVENUE_PASSWORD=change-me-in-production

# Revenue email recipient
REVENUE_EMAIL=owner@yourdomain.com

# Sentry (optional)
SENTRY_DSN=https://...@sentry.io/...
ENVIRONMENT=production
